# ============================================================
# Audio Test RZ/V2H  -  .gitignore
# ============================================================

# --- Rekaman & audio hasil tes (bukan sumber) ---
*.wav
*.raw
*.pcm
rekaman_*.wav
gadget-mic-test.wav

# --- Hasil rekaman video conference (bukan sumber) ---
/recordings/
*.mkv
*.avi

# --- Repo terpisah (punya .git sendiri, jangan di-embed) ---
/video-conference-using-fisheye/

# --- Asset besar (video demo, bukan source code) ---
/aset/

# --- SDK/runtime pihak ketiga, besar & bisa diunduh ulang (bukan source code) ---
/onnxruntime-linux-x64-1.24.3/
/rzv2h_ai-sdk_yocto_recipe_v5.00.tar.gz

# --- Dokumen hasil-generate (Word/PowerPoint) ---
*.doc
*.docx
*.ppt
*.pptx
~$*

# --- Log ---
*.log
alsaloop.log

# --- Claude Code (setelan lokal per-mesin) ---
.claude/settings.local.json

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*~

# --- OS junk ---
Thumbs.db
desktop.ini
.DS_Store

# --- Temp ---
*.tmp
/scratch/
/tmp/

# ============================================================
# CATATAN: modul kernel (*.ko) di usb-audio-modules/ dan
# usb-gadget-modules/ SENGAJA di-commit (prebuilt untuk kernel
